# ── PixelPro Production Environment Variables ─────────────────────────────────
# Copy this to .env on your server / paste into Railway / Render dashboard
# Never commit the actual .env file to git!

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=PixelPro
DEBUG=false
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING   # python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ─────────────────────────────────────────────────────────────────
# Option A — Railway PostgreSQL (copy from Railway dashboard)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME

# Option B — SQLite (simple, works on Railway with persistent disk)
# DATABASE_URL=sqlite+aiosqlite:///./pixelpro.db

# ── Redis (Railway Redis add-on or Upstash) ───────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:PORT
CELERY_BROKER_URL=redis://default:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=redis://default:PASSWORD@HOST:PORT/1

# ── Storage ───────────────────────────────────────────────────────────────────
# Option A — Cloudflare R2 (free 10GB, S3-compatible)
AWS_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
AWS_REGION=auto
AWS_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET_INPUT=pixelpro-inputs
S3_BUCKET_OUTPUT=pixelpro-outputs

# Option B — Local file storage (Railway persistent disk mounted at /app/local_storage)
# AWS_ACCESS_KEY_ID=dev
# LOCAL_STORAGE_DIR=/app/local_storage

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your actual frontend domain
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...           # $10/month price ID from Stripe dashboard

# ── AI Edit Providers (both free tiers) ───────────────────────────────────────
FAL_KEY=                              # Optional — https://fal.ai/dashboard/keys
HF_TOKEN=                             # Optional — https://huggingface.co/settings/tokens
# Gradio fallback always works without any key

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24h

# ── Credits ───────────────────────────────────────────────────────────────────
FREE_MONTHLY_CREDITS=500              # Given on signup (3-day trial)
PRO_MONTHLY_CREDITS=500

# ── Sentry (optional — for error tracking) ────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── AI Models ─────────────────────────────────────────────────────────────────
MODELS_DIR=/app/models
MAX_IMAGE_SIZE_MB=20
MAX_BATCH_SIZE=10
