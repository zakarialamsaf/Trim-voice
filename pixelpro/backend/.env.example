# PixelPro Backend — copy to .env.local
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./pixelpro_dev.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pixelpro

# Celery (eager for dev, Redis for prod)
CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
# CELERY_BROKER_URL=redis://localhost:6379/0

# S3 / Storage (set AWS_ACCESS_KEY_ID=dev to use local file storage)
AWS_ACCESS_KEY_ID=dev
AWS_SECRET_ACCESS_KEY=dev
AWS_REGION=us-east-1
S3_BUCKET_INPUT=pixelpro-inputs
S3_BUCKET_OUTPUT=pixelpro-outputs

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# AI Models
MODELS_DIR=./models
MAX_IMAGE_SIZE_MB=20

# AI Edit Providers (get free keys below)
FAL_KEY=          # https://fal.ai/dashboard/keys
HF_TOKEN=         # https://huggingface.co/settings/tokens
